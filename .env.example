# Copy to .env and fill in real values. .env is gitignored (Day 2) — this file
# documents the SHAPE of the secrets, never the values themselves.
# In real hosting these come from the platform's secret store, not a file.

# Postgres password. Compose uses it for both the db service and the
# DATABASE_URL it hands the backend.
DB_PASSWORD=postgres

# Google Gemini API key — the model + embedding provider (services/llm.py).
GEMINI_API_KEY=your-gemini-api-key-here
